# Environment Configuration
NODE_ENV=development
PORT=4000

# Database - Neon PostgreSQL
# Get your connection string from: https://neon.tech
DATABASE_URL=postgresql://username:password@host.neon.tech/database?sslmode=require

# CORS Origins - Comma-separated list of allowed origins
# In production, update this with your actual frontend URL(s)
# Your frontend: https://monopoly-project-phi.vercel.app/
CORS_ORIGINS=https://monopoly-project-phi.vercel.app
